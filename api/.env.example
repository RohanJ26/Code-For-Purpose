# Google Gemini API Configuration
GEMINI_API_KEY=GEMINI_API_KEY
# Optional model (default gemini-2.5-flash). Gemini 1.5 IDs are retired for many keys (404); use 2.x/3.x only.
# Examples: gemini-2.5-flash, gemini-2.0-flash, gemini-2.0-flash-001, gemini-3-flash-preview
# GEMINI_MODEL=gemini-2.5-flash

# Environment
ENVIRONMENT=development

# Server Configuration
DEBUG=True
LOG_LEVEL=INFO

# Data Configuration
DATA_DIR=/tmp/datasets
MAX_UPLOAD_SIZE=104857600  # 100MB

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
